PORT=3000

# slice 21 — Google Sheets writer (only outbound API in the prototype)
# Leave both blank to run npm run write-sheet in dry-run mode.
GOOGLE_SHEETS_SHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_JSON_PATH=./.credentials/sheets-sa.json

# slice 23 — JSON API
# Single hardcoded bearer token for the prototype. Rotate before any real handoff.
API_BEARER_TOKEN=
